          "variableJumpHeight": {
            "name": "Variable Jump Height",
            "desc": "Releasing jump early dampens upward velocity, giving short/tall jump variation."
          },
          "debugMode": {
            "name": "Debug Mode",
            "desc": "Print contact classification and velocity state to the browser console each tick."
